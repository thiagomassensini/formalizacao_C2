theorem c2ScaledSeededExplicitOddTailRectangularCentralResidualZero_of_C0ZetaCutoffGenuineIdentity
    {tiltSeed : ℂ → ℂ}
    {coreCutoff : ℕ → ℕ} {K M : ℕ}
