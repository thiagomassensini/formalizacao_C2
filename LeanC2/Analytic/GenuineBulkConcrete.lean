theorem c2ScaledSeededExplicitOddTailC0ZetaCutoffGenuineIdentity_iff_rectangularCentralResidualZero
    (tiltSeed : ℂ → ℂ)
    (coreCutoff : ℕ → ℕ) (K M : ℕ)
