      (K := K) (M := M) (J := J) (X := X)
      hexpansion
      (c2ExponentialPointwiseOscillatoryRemainderTerm_norm_le_upper
        K M J X (s := s) hJ)

theorem
    c2ConcreteAntiMiracleResidual_norm_le_exponentialPointwiseOscillatoryUpper_of_eq_canonicalRemainder_three
    {tiltSeed : ℂ → ℂ} {coreCutoff : ℕ → ℕ} {K M : ℕ}
