  fun s => ∑ m ∈ oddCoresUpTo M, ‖complexDirichletCoeff s m‖

lemma c2RectangularOddCoreFiniteUpper_nonneg (M : ℕ) (s : ℂ) :
    0 ≤ c2RectangularOddCoreFiniteUpper M s := by
  unfold c2RectangularOddCoreFiniteUpper
