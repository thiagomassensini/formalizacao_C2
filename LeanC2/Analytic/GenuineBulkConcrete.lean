    cutoffConstant cutoffScale s}

theorem
    c2OddTailContinuedBalancingSeedBulkQuartetClosed_mem_of_zetaDepthCoreRegion
    {coreCutoff : ℕ → ℕ} {K M : ℕ}
    {depthUpper coreUpper eulerUpper zetaUpper : ℂ → ℝ}
