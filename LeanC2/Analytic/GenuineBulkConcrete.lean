noncomputable def C2ExpandedScalarMiddleRegionData.toCanonicalCoverData
    {coreCutoff : ℕ → ℕ} {K M : ℕ}
    {tiltConstant tiltScale
      horizontalConstant horizontalScale horizontalRatio
