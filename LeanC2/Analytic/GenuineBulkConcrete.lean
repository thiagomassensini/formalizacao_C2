      (c2RectangularOddCoreBound_finite M s)
  have hodd :
      C2ContinuedOddChannelBound
        (c2ExplicitFiniteCoreOddUpper c2RiemannZetaExactUpper) s := by
    simpa [c2ExplicitFiniteCoreOddUpper] using
